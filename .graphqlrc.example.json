{
  "schema": "http://localhost:4000/graphql",
  "documents": [
    "./graphql/**/*.graphql",
    "./graphql/**/*.gql"
  ],
  "extensions": {
    "endpoints": {
      "default": {
        "url": "http://localhost:4000/graphql",
        "headers": {
          "Authorization": "Bearer ${API_TOKEN}",
          "Content-Type": "application/json"
        }
      }
    }
  }
}